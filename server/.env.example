# NYAYPATRA Backend Environment Configuration (port 5000)
# Copy this to .env and fill in your values

# Optional: OpenAI API Key for real AI explanations and chat
# If not set, the server will use intelligent mock responses
OPENAI_API_KEY=

# NYAYPATRA Server port (default: 5000)
NYAYPATRA_PORT=5000

# ============================================================
# KISAN NADI Backend Environment Configuration (port 3001)
# ============================================================

# Server Configuration
PORT=3001

# OpenWeatherMap API (https://openweathermap.org/api)
# Free tier available - sign up for API key
OPENWEATHER_API_KEY=your_openweather_api_key_here

# data.gov.in API (https://data.gov.in)
# Free API key required for AGMARKNET and CROP ADVISORY data
DATA_GOV_API_KEY=your_data_gov_api_key_here

# NASA POWER API - No key required (completely free and open)
NASA_POWER_ENABLED=true
